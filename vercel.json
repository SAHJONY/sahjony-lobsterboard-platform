{
  "version": 2,
  "builds": [
    {
      "src": "dist/server/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/dist/server/server.js"
    }
  ],
  "functions": {
    "dist/server/server.js": {
      "includeFiles": "dist/client/**"
    }
  },
  "installCommand": "npm install",
  "buildCommand": "npm run build"
}